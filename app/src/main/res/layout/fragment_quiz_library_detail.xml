<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".quizlibraryfeatures.QuizLibraryFeaturesFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:minHeight="?attr/actionBarSize"
            app:contentScrim="?attr/colorSurface"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:statusBarScrim="?attr/colorSurface"
            app:titleEnabled="false"
            app:toolbarId="@id/toolbar">

            <LinearLayout
                android:id="@+id/quiz_library_app_bar_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="56dp"
                android:paddingBottom="8dp"
                app:layout_collapseMode="parallax">

                <TextView
                    android:id="@+id/library_title_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="30-1、2-配电安规-配电一次运检专业" />

                <TextView
                    android:id="@+id/library_stats_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    tools:text="共 120 题 · 单选 50 · 多选 30 · 判断 40" />

                <LinearLayout
                    android:id="@+id/library_detect_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="start|center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/camera_button"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="8dp"
                        android:contentDescription="@string/camera_button_description"
                        android:minHeight="48dp"
                        android:text="扫描搜题"
                        app:icon="@drawable/round_photo_camera_24"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/screen_record_button"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:padding="8dp"
                        android:contentDescription="@string/screen_button_description"
                        android:minHeight="48dp"
                        android:text="屏幕搜题"
                        app:icon="@drawable/round_picture_in_picture_24"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconSize="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/accessibility_search_button"
                        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="@string/accessibility_search_button_description"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        app:icon="@drawable/icon_accessible_forward_24px"
                        app:iconSize="20dp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorSurface"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/round_arrow_back_24"
                tools:title="题库" />
        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/study_features_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <View
        android:id="@+id/status_bar_scrim"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="?attr/colorSurface"
        android:elevation="0dp"
        android:importantForAccessibility="no" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
