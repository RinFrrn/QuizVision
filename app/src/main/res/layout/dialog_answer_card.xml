<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/unanswered_count_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="未答 0"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/answered_count_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="已答 0"
            android:textColor="?attr/colorTertiary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/correct_count_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="正确 0"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/incorrect_count_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="错误 0"
            android:textColor="?attr/colorError"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/total_count_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp"
        android:text="共 0 题"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/answer_card_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager" />
</LinearLayout>
